# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cr_platform
DB_USER=root
DB_PASSWORD=your_password

# Jira Configuration
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token

# Claude API Configuration
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Cursor Cloud Agent (optional, 优先级高于 CLAUDE_API_KEY)
# 拿 KEY: https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=
CURSOR_AGENT_REPO_URL=
CURSOR_AGENT_REPO_REF=master
CURSOR_AGENT_MODEL=auto
CURSOR_AGENT_POLL_INTERVAL=5
CURSOR_AGENT_TIMEOUT=600

# GitHub（发布版本下拉 + 本版 vs 上一版 diff）
GITHUB_REPO=yinwanli/ai-CR
GITHUB_DEFAULT_BRANCH=main
GITHUB_TOKEN=
GITHUB_COMMITS_LIMIT=30

# Authentication
AUTH_TOKEN=your_auth_token

# Frontend URL
FRONTEND_URL=http://localhost:5173

# AI Configuration
SINGLE_CALL_TIMEOUT=60
TOTAL_ANALYSIS_TIMEOUT=300
MAX_CONTEXT_FILES=5
MAX_FILE_LINES=500

# File Filter Configuration
EXCLUDE_PATTERNS=*.vue,*.jsx,*.tsx,*.css,*.scss,*.less,*.html,*.js,*.ts,package.json,package-lock.json,yarn.lock,pnpm-lock.yaml
INCLUDE_PATTERNS=*.py,*.java,*.go,*.sql
EXCLUDE_DIRS=node_modules/,dist/,build/,.venv/,venv/,__pycache__/

# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG
